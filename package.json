{
  "name": "inti-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Inti Education Platform - Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "api:dev": "npm --prefix apps/api run dev",
    "web:dev": "npm --prefix apps/web-admin run dev",
    "mobile:dev": "npm --prefix apps/mobile-app run start",
    "types:build": "npm --prefix packages/shared-types run build",
    "types:watch": "npm --prefix packages/shared-types run watch",
    "start": "./start.sh",
    "start:api": "npm run api:dev",
    "start:web": "npm run web:dev",
    "start:mobile": "npm run mobile:dev",
    "build:api": "npm --prefix apps/api run build",
    "build:web": "npm --prefix apps/web-admin run build",
    "build:mobile": "npm --prefix apps/mobile-app run build",
    "railway:web:build": "npm run types:build && npm --prefix apps/web-admin run build",
    "railway:web:start": "npm --prefix apps/web-admin run start",
    "docker:dev": "./rebuild.sh",
    "docker:deploy": "./deploy.sh"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "csstype": "3.0.10",
    "react-native-reanimated": "3.16.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.2.0"
}
